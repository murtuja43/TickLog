# =============================================================================
# Git ignore rules for an Android / Gradle project.
# =============================================================================

# --- Built output --------------------------------------------------------------
*.apk
*.aar
*.ap_
*.aab
*.dex
*.class
bin/
gen/
out/
build/
release/

# --- Gradle --------------------------------------------------------------------
.gradle/
local.properties

# --- Android Studio / IntelliJ -------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
captures/
.externalNativeBuild/
.cxx/

# --- Keystores & signing (never commit signing material) -----------------------
*.jks
*.keystore
keystore.properties

# --- OS / editor noise ---------------------------------------------------------
.DS_Store
*.log
*.tmp
*.swp

# Kotlin build daemon session files
.kotlin/
