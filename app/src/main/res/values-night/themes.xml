<?xml version="1.0" encoding="utf-8"?>
<!--
    Dark-mode counterpart of the window theme: a pure-black background so the
    launch window matches the dark Compose UI with no white flash.
-->
<resources>
    <style name="Theme.TickLog" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
