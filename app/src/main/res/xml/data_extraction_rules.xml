<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup / transfer rules for Android 12+ (cloud backup and device-to-device).
    Persist the user's checklist database and preferences across both channels.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="." />
        <include domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
