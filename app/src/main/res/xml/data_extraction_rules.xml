<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup / transfer rules for Android 12+ (cloud backup and device-to-device).

    TickLog keeps all data on-device, so EVERY domain is excluded from both
    channels: nothing is uploaded to cloud backup and nothing is copied during a
    device-to-device transfer. Users migrate their data explicitly via the app's
    own Backup & Restore (a local file they choose). See allowBackup="false" in
    the manifest for the pre-Android-12 equivalent.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
