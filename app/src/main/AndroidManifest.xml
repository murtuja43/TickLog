<?xml version="1.0" encoding="utf-8"?>
<!--
    TickLog manifest.

    Notes:
    * No <uses-permission> entries — the app is fully offline and never touches
      the network, the file system outside its sandbox, or any sensitive APIs.
    * resizeableActivity + no fixed orientation => full tablet and landscape
      support out of the box.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Backup is disabled so data never leaves the device. allowBackup="false"
        turns off cloud backup (all API levels); data_extraction_rules then
        excludes every domain from BOTH cloud backup and device-to-device
        transfer (on Android 12+, allowBackup no longer covers D2D). Migration is
        served by the app's own explicit, user-controlled Backup & Restore. This
        keeps the privacy claim literally true and the Play Data Safety answers
        simple: no data collected, shared, or transferred off-device.
    -->
    <application
        android:name=".TickLogApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:resizeableActivity="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TickLog"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode"
            android:launchMode="singleTop"
            android:theme="@style/Theme.TickLog.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Home-screen widget. Listens for the standard app-widget update, plus
            the system day-rollover broadcasts so "today" refreshes at midnight
            (and on manual clock/timezone changes) without any polling.
        -->
        <receiver
            android:name=".ui.feature_widget.TickLogWidgetReceiver"
            android:exported="false"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.DATE_CHANGED" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/ticklog_widget_info" />
        </receiver>

        <!--
            Grants other apps temporary, scoped read access to generated PDF
            reports (for share / open), without any storage permission.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
