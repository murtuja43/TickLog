# =============================================================================
# Release signing configuration — TEMPLATE.
# -----------------------------------------------------------------------------
# Copy this file to `keystore.properties` (which is git-ignored) and fill in the
# values for YOUR upload keystore. This file is only a template and contains no
# secrets. The build reads these at configuration time; alternatively, set the
# matching environment variables (shown in brackets) in CI instead of a file.
#
#   cp keystore.properties.example keystore.properties
#
# Never commit keystore.properties or the .jks/.keystore file itself.
# =============================================================================

# Path to your keystore file, relative to the repo root (or absolute).
#   [env: TICKLOG_KEYSTORE_FILE]
storeFile=ticklog-upload.jks

# Password for the keystore.
#   [env: TICKLOG_KEYSTORE_PASSWORD]
storePassword=CHANGE_ME

# Alias of the key inside the keystore.
#   [env: TICKLOG_KEY_ALIAS]
keyAlias=ticklog

# Password for that key (often the same as the store password).
#   [env: TICKLOG_KEY_PASSWORD]
keyPassword=CHANGE_ME
